# ============================================================
# Arminda — variáveis de ambiente (template)
# Copie este arquivo para .env e ajuste os valores.
# NUNCA commite o .env real.
# ============================================================

# ---------- Django ----------
DJANGO_SECRET_KEY=change-me-in-production-use-django-secret-key-generator
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=arminda.settings.dev

# ---------- Banco de dados (PostgreSQL) ----------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=arminda
POSTGRES_USER=arminda
POSTGRES_PASSWORD=arminda_dev_password

# URL completa (alternativa às variáveis acima)
DATABASE_URL=postgresql://arminda:arminda_dev_password@localhost:5432/arminda

# ---------- Redis / Celery ----------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ---------- CORS / Frontend ----------
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---------- Frontend (Vite) ----------
# Variáveis prefixadas com VITE_ ficam disponíveis no client
VITE_API_URL=http://localhost:8000/api
VITE_APP_NAME=Arminda

# ---------- Observabilidade (opcional, fase futura) ----------
SENTRY_DSN=
LOG_LEVEL=INFO
