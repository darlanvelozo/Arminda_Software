        Body:
            {
              "contexto": {
                "SALARIO_BASE": "1320.00",
                "IDADE": 35,
                "DEPENDENTES": 2
              },
              "rubricas_calculadas": {              # opcional
                "SAL_BASE": "1320.00"
              }
            }

        Resposta:
            { "valor": "132.00", "formula": "SALARIO_BASE * 0.10" }

        Erros (HTTP 400):
            { "detail": "...", "code": "FORMULA_VARIAVEL_AUSENTE" }
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this rubrica.
