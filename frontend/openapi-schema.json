          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/UsuarioMunicipioPapelCreate'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/UsuarioMunicipioPapelCreate'
        required: true
      security:
      - jwtAuth: []
      - cookieAuth: []
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/UsuarioMunicipioPapelCreate'
          description: ''
