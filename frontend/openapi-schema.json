  /api/payroll/folhas/:
    get:
      operationId: payroll_folhas_list
      description: |-
        CRUD de folhas + endpoint `/calcular/` que dispara o cálculo
        mensal usando o engine (apps.calculo).

        Permissões:
        - list/retrieve/lancamentos: leitura (qualquer papel).
        - create/update/destroy: financeiro/admin/staff.
        - calcular: financeiro/admin/staff (é uma operação de escrita).
      parameters:
      - in: query
        name: ano
        schema:
          type: number
      - in: query
        name: competencia
        schema:
          type: string
          format: date
      - in: query
        name: competencia_ate
        schema:
          type: string
          format: date
      - in: query
        name: competencia_de
        schema:
          type: string
          format: date
      - in: query
        name: mes
        schema:
          type: number
      - name: ordering
        required: false
        in: query
        description: Which field to use when ordering the results.
        schema:
          type: string
      - name: page
        required: false
        in: query
        description: A page number within the paginated result set.
        schema:
          type: integer
      - name: search
        required: false
        in: query
        description: A search term.
        schema:
          type: string
      - in: query
        name: status
        schema:
          type: string
          enum:
          - aberta
          - calculada
          - conferida
          - fechada
        description: |-
          * `aberta` - Aberta
          * `calculada` - Calculada
          * `conferida` - Conferida
          * `fechada` - Fechada
      - in: query
        name: tipo
        schema:
          type: string
          enum:
          - 13_primeira
          - 13_segunda
          - complementar
          - ferias
          - licenca_premio
          - mensal
          - rescisao
        description: |-
          * `mensal` - Mensal
          * `13_primeira` - 13o - 1a parcela
          * `13_segunda` - 13o - 2a parcela
          * `ferias` - Ferias
          * `rescisao` - Rescisao
          * `licenca_premio` - Licença-prêmio (indenização)
          * `complementar` - Complementar
      tags:
      - payroll
      security:
      - jwtAuth: []
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedFolhaListList'
          description: ''
    post:
      operationId: payroll_folhas_create
      description: |-
        CRUD de folhas + endpoint `/calcular/` que dispara o cálculo
        mensal usando o engine (apps.calculo).

        Permissões:
        - list/retrieve/lancamentos: leitura (qualquer papel).
        - create/update/destroy: financeiro/admin/staff.
        - calcular: financeiro/admin/staff (é uma operação de escrita).
      tags:
      - payroll
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/FolhaWrite'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/FolhaWrite'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/FolhaWrite'
        required: true
      security:
