components:
  schemas:
    AdmissaoInput:
      type: object
      description: |-
        Input para POST /api/people/servidores/admitir/.

        Espelha apps.people.services.admissao.DadosAdmissao.
      properties:
        matricula:
          type: string
          maxLength: 30
        nome:
          type: string
          maxLength: 200
        cpf:
          type: string
          maxLength: 14
        data_nascimento:
          type: string
          format: date
        sexo:
          type: string
          maxLength: 1
        estado_civil:
          type: string
          maxLength: 20
        pis_pasep:
          type: string
          maxLength: 20
        email:
          type: string
          format: email
        telefone:
          type: string
          maxLength: 20
        cargo_id:
          type: integer
        lotacao_id:
          type: integer
        regime:
          type: string
          maxLength: 30
        data_admissao:
          type: string
          format: date
        salario_base:
          type: string
          format: decimal
          pattern: ^-?\d{0,10}(?:\.\d{0,2})?$
        carga_horaria:
          type: integer
          maximum: 60
          minimum: 1
          default: 40
      required:
      - cargo_id
      - cpf
      - data_admissao
      - data_nascimento
      - lotacao_id
      - matricula
      - nome
      - regime
      - salario_base
      - sexo
    ArmindaTokenObtainPair:
      type: object
      description: 'Login: gera tokens com claims customizadas e retorna dados do
        usuario.'
      properties:
        email:
          type: string
          writeOnly: true
        password:
          type: string
          writeOnly: true
      required:
      - email
      - password
    BlankEnum:
      enum:
      - ''
    CargoDetail:
      type: object
      description: Versao completa para retrieve.
      properties:
        id:
          type: integer
          readOnly: true
        codigo:
          type: string
          maxLength: 20
        nome:
          type: string
          maxLength: 200
        cbo:
          type: string
          maxLength: 10
        nivel_escolaridade:
          $ref: '#/components/schemas/NivelEscolaridadeEnum'
        nivel_escolaridade_display:
          type: string
          readOnly: true
        ativo:
          type: boolean
        criado_em:
          type: string
          format: date-time
          readOnly: true
        atualizado_em:
          type: string
          format: date-time
          readOnly: true
      required:
      - atualizado_em
      - codigo
      - criado_em
      - id
      - nivel_escolaridade_display
      - nome
    CargoList:
      type: object
      description: Versao enxuta para listagem.
      properties:
        id:
          type: integer
          readOnly: true
        codigo:
          type: string
          readOnly: true
        nome:
          type: string
          readOnly: true
        nivel_escolaridade:
          allOf:
          - $ref: '#/components/schemas/NivelEscolaridadeEnum'
          readOnly: true
        nivel_escolaridade_display:
          type: string
          readOnly: true
        ativo:
          type: boolean
          readOnly: true
      required:
      - ativo
      - codigo
      - id
      - nivel_escolaridade
      - nivel_escolaridade_display
      - nome
    CargoWrite:
      type: object
      description: Versao para create/update.
      properties:
        id:
          type: integer
          readOnly: true
        codigo:
          type: string
          maxLength: 20
        nome:
          type: string
          maxLength: 200
        cbo:
          type: string
          maxLength: 10
        nivel_escolaridade:
          $ref: '#/components/schemas/NivelEscolaridadeEnum'
