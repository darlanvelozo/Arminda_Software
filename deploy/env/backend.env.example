# /opt/arminda/.env  —  produção
#
# IMPORTANTE: o `.env` fica na RAIZ do projeto (mesmo nível de backend/
# e frontend/), não dentro de backend/. Convenção do
# `settings/base.py: read_env(BASE_DIR.parent / ".env")`.
#
# Template. Copie para `.env` (modo 600, owner arminda:arminda) e
# preencha os valores marcados como TROCAR_*. Nunca commitar o .env real.
#
# O `setup-producao.sh` gera esse arquivo automaticamente na primeira
# instalação (com SECRET_KEY e senha de banco aleatórias).

# ============================================================
# Django core
# ============================================================
DJANGO_SETTINGS_MODULE=arminda.settings.prod

# Gere um valor único com: openssl rand -hex 32
DJANGO_SECRET_KEY=TROCAR_GERAR_VALOR_ALEATORIO_DE_64_HEX_CHARS

DJANGO_DEBUG=False

# Hosts aceitos. Em produção, sempre o domínio público.
DJANGO_ALLOWED_HOSTS=arminda.site,www.arminda.site

# Origens permitidas para CSRF (necessário pra POST do admin via Nginx)
DJANGO_CSRF_TRUSTED_ORIGINS=https://arminda.site,https://www.arminda.site

# CORS — origens do frontend autorizadas a chamar a API
CORS_ALLOWED_ORIGINS=https://arminda.site,https://www.arminda.site

# ============================================================
# PostgreSQL
# ============================================================
# Format: postgres://user:password@host:port/dbname
# Em produção rodando na mesma VPS, usar loopback (127.0.0.1).
DATABASE_URL=postgres://arminda:TROCAR_SENHA_GERADA@127.0.0.1:5432/arminda_prod

# ============================================================
# Email (opcional — para envio de boas-vindas, reset de senha etc.)
# ============================================================
# Em desenvolvimento o Django usa console backend.
# Em produção, configure um provedor (ex.: Brevo, SendGrid, AWS SES).
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=noreply@arminda.site
