# frontend/.env.production  —  produção
#
# Copie para `frontend/.env.production` ANTES de rodar `npm run build`.
# Vite injeta essas variáveis (todas com prefixo VITE_) no bundle final.

# URL pública do backend. Em produção, o Nginx aceita /api/ no mesmo
# domínio, então fica vazio (URLs relativas).
# Em dev/demo apontamos para localhost:8000 ou para a URL do tunnel.
VITE_API_BASE_URL=
